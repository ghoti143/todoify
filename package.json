{
  "name": "todoify",
  "private": true,
  "scripts": {
    "setup": "dotnet restore ./server/src/Todoify.Api && npm install --prefix ./client",
    "dev": "concurrently \"dotnet run --project ./server/src/Todoify.Api\" \"npm run dev --prefix ./client\"",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "lint": "dotnet format ./server/src/Todoify.Api --verify-no-changes && npm run lint --prefix ./client",
    "test": "npm run test:unit && npm run test:int",
    "test:unit": "dotnet test ./server/tests/Todoify.Api.UnitTests && npm run test --prefix ./client",
    "test:int": "dotnet test ./server/tests/Todoify.Api.IntegrationTests",
    "stop": "pkill -f Todoify.Api || true && pkill -f vite || true"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
